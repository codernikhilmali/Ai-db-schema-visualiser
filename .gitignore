# ==========================================
# Root Gitignore for AI System Designer
# ==========================================

# Local environment variables (CRITICAL: Never commit credentials)
**/.env
**/.env.local
**/.env.development.local
**/.env.test.local
**/.env.production.local
**/*.local
**/testGemini.js
**/TestGeminiJava.class
**/TestGeminiJava.java

# ------------------------------------------
# Java / Maven Backend (ai-based-schema-visualiser)
# ------------------------------------------
**/target/
**/.mvn/wrapper/maven-wrapper.jar
**/*.class
**/HELP.md
!**/src/main/**/target/
!**/src/test/**/target/

# ------------------------------------------
# React / Node / Vite Frontend (ai-system-designer)
# ------------------------------------------
**/node_modules/
**/dist/
**/dist-ssr/
**/*.log
**/npm-debug.log*
**/yarn-debug.log*
**/yarn-error.log*
**/pnpm-debug.log*
**/lerna-debug.log*

# ------------------------------------------
# IDEs and Editors
# ------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*.suo
*.ntvs*
*.njsproj
*.sln
*.iml
*.iws
*.ipr
.DS_Store
Thumbs.db
