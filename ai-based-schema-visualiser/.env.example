# Spring Boot Backend Environment Variables Example
# Copy this file to '.env' and fill in your actual credentials.

# ------------------------------------------
# Database Configuration (MySQL)
# ------------------------------------------
DB_URL=jdbc:mysql://localhost:3306/ai_schema_visualiser
DB_USERNAME=root
DB_PASSWORD=your_mysql_root_password_here

# ------------------------------------------
# Server Configuration
# ------------------------------------------
PORT=8080

# ------------------------------------------
# Security & JWT Configuration
# ------------------------------------------
# Ensure the secret key is long enough for HS256 (at least 256 bits / 32 characters)
JWT_SECRET=your_super_secret_jwt_signing_key_that_is_at_least_32_characters_long
JWT_ACCESS_EXPIRATION=864000000
JWT_REFRESH_EXPIRATION=6048000000

# ------------------------------------------
# CORS Configuration
# ------------------------------------------
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8080

# ------------------------------------------
# Google Gemini API Keys (Comma-separated list for failover and rotation)
# ------------------------------------------
GEMINI_API_KEYS=YOUR_API_KEY_1,YOUR_API_KEY_2,YOUR_API_KEY_3
